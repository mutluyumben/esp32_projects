#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <UniversalTelegramBot.h>
#include <ArduinoJson.h>

const char* ssid = "***";
const char* password = "***";

#define BOTtoken "***"
#define CHAT_ID "***"

const int trigPin = 9;
const int echoPin = 10;
bool mesajGonderildi = false;

WiFiClientSecure client;
UniversalTelegramBot bot(BOTtoken, client);

void setup() {
  Serial.begin(115200);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  WiFi.begin(ssid, password);
  client.setInsecure(); 

  Serial.println("WiFi Baglaniyor...");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("WiFi Baglandi!");
  bot.sendMessage(CHAT_ID, "Guvenlik Sistemi Aktif!", "");
}

void loop() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH);
  float distanceCm = duration * 0.034 / 2;

  if (distanceCm > 50 && distanceCm < 400) {
    if (!mesajGonderildi) {
      Serial.println("Kapi Acildi! Telegram mesaji gonderiliyor...");
      bot.sendMessage(CHAT_ID, "UYARI: Kapi acildi!", "");
      mesajGonderildi = true; 
    }
  } 
  else if (distanceCm > 0 && distanceCm <= 50) {
    mesajGonderildi = false; 
  }

  delay(1000); 
}
